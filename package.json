{
  "name": "@rivalhub/rival-rating",
  "version": "0.1.0",
  "description": "RR (Rival Rating) scalar engine + PRISM eight-dimension radar",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./weights/*": "./src/weights/*"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "demo:download": "node scripts/download-hltv-demos.mjs",
    "demo:parse": "python3 scripts/awpy-demo-to-analysis.py",
    "fixture:account": "node scripts/analysis-to-account-fixture.mjs",
    "fixture:freeze": "UPDATE_ACCOUNT_FIXTURE_EXPECTED=1 vitest run src/rr/models/account-regression-fixtures.test.ts"
  },
  "packageManager": "pnpm@11.0.8",
  "devDependencies": {
    "@types/node": "^25.9.1",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  }
}
